{
  "name": "exam-saas-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Secure API for the Exampo SaaS application",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
